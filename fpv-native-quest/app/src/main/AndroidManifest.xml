<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Android 11+ (API 30) package visibility: without <queries>, PackageManager
        hides other apps' services from us.  The Khronos OpenXR loader discovers the
        Meta Quest runtime by querying for services with these action names.
        Without these entries the loader returns XR_ERROR_RUNTIME_UNAVAILABLE (-51)
        because it cannot see the Meta OpenXR runtime service on Quest 2/3.
    -->
    <queries>
        <intent>
            <action android:name="org.khronos.openxr.OpenXRRuntimeService" />
        </intent>
        <intent>
            <action android:name="org.khronos.openxr.OpenXRApiLayerService" />
        </intent>
    </queries>

    <!-- Network access for WebSocket signaling and WebRTC ICE -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- TASK-007: WiFi High Performance Lock — disables power-save mode during streaming.
         WAKE_LOCK is required by WIFI_MODE_FULL_HIGH_PERF (it holds a wake lock internally).
         CHANGE_WIFI_STATE is required to create the WifiLock. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Quest 2 VR hardware requirements -->
    <uses-feature
        android:name="android.hardware.vr.headtracking"
        android:required="true"
        android:version="1" />

    <!-- Hand tracking (optional — used for controller input in future tasks) -->
    <uses-permission
        android:name="com.oculus.permission.HAND_TRACKING"
        android:required="false" />

    <application
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:hardwareAccelerated="true"
        android:allowBackup="false"
        android:supportsRtl="false">

        <!--
            Main activity: fullscreen landscape, no title bar.
            Quest 2 renders in landscape; configChanges prevents recreation
            on orientation/keyboard changes inside the VR session.
        -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:configChanges="density|keyboard|keyboardHidden|navigation|orientation|screenLayout|screenSize|uiMode"
            android:launchMode="singleTask"
            android:resizeableActivity="false">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <!-- Standard Android launcher -->
                <category android:name="android.intent.category.LAUNCHER" />
                <!-- Quest / Horizon OS launcher -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
                <!--
                    com.oculus.intent.category.VR is required for the Activity to survive
                    the 2D→VR lifecycle transition.  Without it, Quest terminates the
                    Activity (onPause → onStop → onDestroy) as soon as the 2D panel is
                    hidden when the OpenXR session reaches FOCUSED state.
                    With it, Quest keeps the Activity alive in VR mode. The 2D Android
                    views (URL input, buttons) appear as a floating panel in VR space;
                    the user interacts via Quest controllers and the virtual keyboard.
                -->
                <category android:name="com.oculus.intent.category.VR" />
            </intent-filter>

            <!--
                focusaware=true: required for OpenXR XR_SESSION_STATE_FOCUSED.
                Without this the runtime keeps the session in VISIBLE state and
                controller/hand input is not delivered to the app.
            -->
            <meta-data
                android:name="com.oculus.vr.focusaware"
                android:value="true" />

        </activity>

    </application>

</manifest>
